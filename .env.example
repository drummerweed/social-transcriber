# Notion Internal Integration Token
# Create one at: https://www.notion.so/my-integrations
NOTION_TOKEN="ntn_YOUR_TOKEN_HERE"

# Notion Database ID
# Extract it from your database URL: https://www.notion.so/USER/DATABASE_ID?v=...
NOTION_DATABASE_ID="YOUR_DATABASE_ID_HERE"

# Optional: Webhook Secret Token (for security)
WEBHOOK_TOKEN="wh_sec_YOUR_TOKEN_HERE"

# Filename for cookies (optional, e.g., for YouTube downloads)
COOKIES_FILE="cookies.txt"
